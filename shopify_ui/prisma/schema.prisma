// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─────────────────────────────────────────
// Multi-Tenancy (keyed by Shopify shop domain)
// ─────────────────────────────────────────
model ShopifyUser {
  shopDomain    String   @id
  shopifyUserId BigInt?
  email         String?
  firstName     String?
  installedAt   DateTime @default(now())

  products          ShopifyProduct[]
  scrapedProducts   ScrapedProduct[]
  scrapingConfigs   ScrapingConfig[]
  scrapingErrors    ScrapingError[]
  productUrls       ProductUrl[]
  productEmbeddings ProductEmbedding[]
}

// ─────────────────────────────────────────
// INTERNAL: Shopify Store Data
// ─────────────────────────────────────────
model ShopifyProduct {
  id         String      @id // Shopify GID
  shopDomain String
  shop       ShopifyUser @relation(fields: [shopDomain], references: [shopDomain])

  title       String
  description String  @default("")
  vendor      String?
  productType String  @default("")
  tags        Json    @default("[]")
  imageUrl    String?
  handle      String?
  status      String  @default("ACTIVE")

  dynamicPricingEnabled Boolean  @default(false)
  syncPrice             Boolean  @default(true)
  syncDescription       Boolean  @default(false)
  syncTitle             Boolean  @default(false)
  syncedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ShopifyVariant[]
}

model ShopifyVariant {
  id        String         @id
  productId String
  product   ShopifyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku          String?
  barcode      String?
  title        String  @default("Default Title")
  options      Json?
  imageUrl     String?

  currentPrice  Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?

  updatedAt DateTime @updatedAt

  embedding ShopifyEmbedding?
}

model ShopifyEmbedding {
  id        String         @id @default(uuid())
  variantId String         @unique
  variant   ShopifyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  semanticText   String?
  textEmbedding  Unsupported("vector(768)")?
  imageEmbedding Unsupported("vector(768)")?

  embeddedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────
// COMPETITOR: Scraped External Data
// ─────────────────────────────────────────
model ScrapedProduct {
  id         String      @id @default(uuid())
  shopDomain String
  shop       ShopifyUser @relation(fields: [shopDomain], references: [shopDomain])
  domain     String

  title          String
  description    String?
  vendor         String?
  productType    String?
  tags           Json    @default("[]")
  imageUrl       String?
  specifications Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants   ScrapedVariant[]
  urls       ProductUrl[]
  embeddings ProductEmbedding[]
}

model ScrapedVariant {
  id        String         @id @default(uuid())
  productId String
  product   ScrapedProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku           String?
  barcode       String?
  title         String   @default("Default Title")
  options       Json?
  currentPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?
  semanticText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  embeddings ProductEmbedding[]
}

// ─────────────────────────────────────────
// URL TRACKING
// ─────────────────────────────────────────
enum UrlStatus {
  ACTIVE
  DEAD
  PAUSED
}

model ProductUrl {
  id         String         @id @default(uuid())
  shopDomain String
  shop       ShopifyUser    @relation(fields: [shopDomain], references: [shopDomain])
  configId   String
  config     ScrapingConfig @relation(fields: [configId], references: [id])
  prodId     String
  product    ScrapedProduct @relation(fields: [prodId], references: [id], onDelete: Cascade)

  url           String    @unique
  status        UrlStatus @default(ACTIVE)
  failCount     Int       @default(0)
  lastScrapedAt DateTime?
  nextScrapAt   DateTime?
  createdAt     DateTime  @default(now())
}

// ─────────────────────────────────────────
// EMBEDDINGS
// ─────────────────────────────────────────
model ProductEmbedding {
  id         String  @id @default(uuid())
  shopDomain String
  prodId     String
  variantId  String?

  vectorText     Unsupported("vector(768)")?
  vectorImg      Unsupported("vector(768)")?
  embeddingModel String
  vectorizedAt   DateTime @default(now())

  shop    ShopifyUser    @relation(fields: [shopDomain], references: [shopDomain])
  product ScrapedProduct  @relation(fields: [prodId], references: [id], onDelete: Cascade)
  variant ScrapedVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// SCRAPER CONFIGS
// ─────────────────────────────────────────
enum ScrapeStatus {
  IDLE
  QUEUED
  RUNNING
  SCRAPED_FIRST
}

model ScrapingConfig {
  id                String       @id @default(uuid())
  shopDomain        String
  shop              ShopifyUser  @relation(fields: [shopDomain], references: [shopDomain])
  competitorUrl     String
  includeImages     Boolean      @default(true)
  productLimit      Int?
  frequencyInterval Int?
  nextRunAt         DateTime?
  isActive          Boolean      @default(true)
  status            ScrapeStatus @default(IDLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  productUrls    ProductUrl[]
  scrapingErrors ScrapingError[]
}

// ─────────────────────────────────────────
// SCRAPING ERRORS
// ─────────────────────────────────────────
model ScrapingError {
  id          String      @id @default(uuid())
  shopDomain  String
  shop        ShopifyUser @relation(fields: [shopDomain], references: [shopDomain])
  configId    String
  config      ScrapingConfig @relation(fields: [configId], references: [id])
  productUrl  String
  gcsRef      String?
  errorType   String
  errorDetail String?
  taskName    String
  failedAt    DateTime @default(now())
}
