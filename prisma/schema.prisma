// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator py_client {
  provider                  = "prisma-client-py"
  recursive_type_depth      = 5
  enable_experimental_decimal = true
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─────────────────────────────────────────
// Multi-Tenancy
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  username  String?
  email     String   @unique
  createdAt DateTime @default(now())

  shopifyProducts ShopifyProduct[]
  shopifyVariants ShopifyVariant[]
  scrapedProducts ScrapedProduct[]
  scrapedVariants ScrapedVariant[]
  scrapingConfigs ScrapingConfig[]
}

// ─────────────────────────────────────────
// INTERNAL: Shopify Store Data
// ─────────────────────────────────────────
model ShopifyProduct {
  id     String  @id // Shopify GID
  userId String
  user   User    @relation(fields: [userId], references: [id])
  shop   String // e.g. "mystore.myshopify.com"
  url    String?

  title          String
  description    String  @default("")
  vendor         String?
  productType    String  @default("")
  tags           Json    @default("[]") // Using Json for native array support
  imageUrl       String?
  specifications Json? // Specs escape hatch

  // AI & Vectorization
  semanticText   String?
  textEmbedding  Unsupported("vector(768)")?
  imageEmbedding Unsupported("vector(768)")?
  vectorized     Boolean                     @default(false)

  // MarketOS Dynamic Pricing Strategy
  dynamicChangeEnabled Boolean @default(false)
  fieldPrice           Boolean @default(true)
  fieldDescription     Boolean @default(false)
  fieldTitle           Boolean @default(false)

  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ShopifyVariant[]
}

model ShopifyVariant {
  id        String         @id // Shopify Variant GID or UUID
  productId String
  product   ShopifyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  sku     String?
  barcode String? // UPC/EAN
  title   String  @default("Default Title")
  options Json? // e.g. {"Size": "M", "Color": "Red"}

  currentPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?

  // Variant-level AI
  variantSemanticText String?
  variantEmbedding    Unsupported("vector(768)")?
  vectorized          Boolean                     @default(false)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// COMPETITOR: Scraped External Data
// ─────────────────────────────────────────
model ScrapedProduct {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id])
  productUrl String @unique @map("url")
  domain     String

  title          String
  description    String?
  vendor         String?
  productType    String?
  tags           Json    @default("[]")
  imageUrl       String?
  specifications Json?

  // AI & Vectorization
  semanticText   String?
  textEmbedding  Unsupported("vector(768)")?
  imageEmbedding Unsupported("vector(768)")?
  vectorized     Boolean                     @default(false)

  scrapedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ScrapedVariant[]
}

model ScrapedVariant {
  id        String         @id @default(uuid())
  productId String
  product   ScrapedProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  sku     String?
  barcode String?
  title   String  @default("Default Title")
  options Json?

  currentPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?

  // Variant-level AI
  variantSemanticText String?
  variantEmbedding    Unsupported("vector(768)")?
  vectorized          Boolean                     @default(false)

  scrapedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScrapeStatus {
  IDLE
  QUEUED
  RUNNING
  SCRAPED_FIRST
}

// ─────────────────────────────────────────
// SCRAPER CONFIGS
// ─────────────────────────────────────────
model ScrapingConfig {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  shopId            String? // e.g. "mystore.myshopify.com"
  competitorUrl     String
  includeImages     Boolean      @default(true)
  productLimit      Int?
  frequencyInterval Int? // In hours
  nextRunAt         DateTime?
  isActive          Boolean      @default(true)
  status            ScrapeStatus @default(IDLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}
