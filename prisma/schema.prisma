// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator py_client {
  provider                    = "prisma-client-py"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─────────────────────────────────────────
// Multi-Tenancy
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  username  String?
  email     String   @unique
  createdAt DateTime @default(now())

  shopifyProducts   ShopifyProduct[]
  shopifyVariants   ShopifyVariant[]
  scrapedProducts   ScrapedProduct[]
  scrapedVariants   ScrapedVariant[]
  scrapingConfigs   ScrapingConfig[]
  productUrls       ProductUrl[]
  productEmbeddings ProductEmbedding[]
}

// ─────────────────────────────────────────
// INTERNAL: Shopify Store Data
// ─────────────────────────────────────────
model ShopifyProduct {
  id     String  @id // Shopify GID
  userId String
  user   User    @relation(fields: [userId], references: [id])
  shop   String
  url    String?

  title          String
  description    String  @default("")
  vendor         String?
  productType    String  @default("")
  tags           Json    @default("[]")
  imageUrl       String?
  specifications Json?

  semanticText   String?
  textEmbedding  Unsupported("vector(768)")?
  imageEmbedding Unsupported("vector(768)")?
  vectorized     Boolean                     @default(false)

  dynamicChangeEnabled Boolean @default(false)
  fieldPrice           Boolean @default(true)
  fieldDescription     Boolean @default(false)
  fieldTitle           Boolean @default(false)

  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ShopifyVariant[]
}

model ShopifyVariant {
  id        String         @id
  productId String
  product   ShopifyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  sku     String?
  barcode String?
  title   String  @default("Default Title")
  options Json?

  currentPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?

  variantSemanticText String?
  variantEmbedding    Unsupported("vector(768)")?
  vectorized          Boolean                     @default(false)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// COMPETITOR: Scraped External Data
// ─────────────────────────────────────────
model ScrapedProduct {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  domain String

  title          String
  description    String?
  vendor         String?
  productType    String?
  tags           Json    @default("[]")
  imageUrl       String?
  specifications Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants   ScrapedVariant[]
  urls       ProductUrl[]
  embeddings ProductEmbedding[]
}

model ScrapedVariant {
  id        String         @id @default(uuid())
  productId String
  product   ScrapedProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  sku           String?
  barcode       String?
  title         String  @default("Default Title")
  options       Json?
  currentPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  isInStock     Boolean  @default(true)
  stockQuantity Int?

  // Groq-generated semantic description combining product + variant context
  semanticText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  embeddings ProductEmbedding[]
}

// ─────────────────────────────────────────
// URL TRACKING: one URL per competitor page
// Decouples product identity from URL so the
// same product scraped from multiple URLs
// stays a single ScrapedProduct row.
// ─────────────────────────────────────────
enum UrlStatus {
  ACTIVE
  DEAD
  PAUSED
}

model ProductUrl {
  id       String         @id @default(uuid())
  userId   String
  user     User           @relation(fields: [userId], references: [id])
  configId String
  config   ScrapingConfig @relation(fields: [configId], references: [id])
  prodId   String
  product  ScrapedProduct @relation(fields: [prodId], references: [id], onDelete: Cascade)

  url           String    @unique
  status        UrlStatus @default(ACTIVE)
  failCount     Int       @default(0)
  lastScrapedAt DateTime?
  nextScrapAt   DateTime?
  createdAt     DateTime  @default(now())
}

// ─────────────────────────────────────────
// EMBEDDINGS: one row per variant
// variantId is nullable so a product-level
// image-only embedding can be stored too.
// ─────────────────────────────────────────
model ProductEmbedding {
  id        String  @id @default(uuid())
  userId    String
  prodId    String
  variantId String?

  vectorText     Unsupported("vector(768)")?
  vectorImg      Unsupported("vector(768)")?
  embeddingModel String
  vectorizedAt   DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id])
  product ScrapedProduct  @relation(fields: [prodId], references: [id], onDelete: Cascade)
  variant ScrapedVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// SCRAPER CONFIGS
// ─────────────────────────────────────────
enum ScrapeStatus {
  IDLE
  QUEUED
  RUNNING
  SCRAPED_FIRST
}

model ScrapingConfig {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  shopId            String?
  competitorUrl     String
  includeImages     Boolean      @default(true)
  productLimit      Int?
  frequencyInterval Int?
  nextRunAt         DateTime?
  isActive          Boolean      @default(true)
  status            ScrapeStatus @default(IDLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  productUrls ProductUrl[]
}
